# paikko widget configuration for the calculator example.
#
# These NEXT_PUBLIC_* vars point the mounted widget (<PaikkoProvider> in
# app/PaikkoMount.tsx) at the paikko backend. They are read at build time and
# inlined into the client bundle. Copy this file to .env.local and adjust if
# your backend runs elsewhere.
#
# In this local setup the backend runs on http://localhost:8788 (next dev) and
# this calculator app runs on http://localhost:3000. Reports POST cross-origin
# from :3000 to the backend's /api/reports, and the nav pill links to the
# backend's /tickets review UI.

# Backend reports intake URL the report bundle is POSTed to (cross-origin).
NEXT_PUBLIC_PAIKKO_ENDPOINT=http://localhost:8788/api/reports

# Absolute URL of the backend review queue (the /tickets review UI).
NEXT_PUBLIC_PAIKKO_TICKETS_URL=http://localhost:8788/tickets

# Project/tenant key stamped onto every report (SaaS seam). The backend filters
# the review queue by this key, so it identifies this app's tickets.
NEXT_PUBLIC_PAIKKO_PROJECT_KEY=calculator-demo
