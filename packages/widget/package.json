{
  "name": "@paikko/widget",
  "version": "0.1.0",
  "description": "paikko consumer report widget (PaikkoProvider, ReportButton, PaikkoNav, capture) + provenance plugin. Backend-agnostic: configurable endpoint, projectKey, ticketsUrl.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paikko/paikko.git",
    "directory": "packages/widget"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./build/provenancePlugin": "./src/build/provenancePlugin.cjs"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/build/provenancePlugin.cjs",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@paikko/contract": "*",
    "html2canvas": "^1.4.1",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "react": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
