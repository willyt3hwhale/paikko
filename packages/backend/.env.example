# DATABASE_URL is used ONLY by the Prisma CLI for local tooling (migrate diff,
# studio). It is NOT the runtime connection on Cloudflare Workers: there, Prisma
# connects through the D1 binding (`DB`) supplied by @prisma/adapter-d1, not this
# URL. Copy to .env (gitignored) for CLI use.
DATABASE_URL="file:./dev.db"

# PAIKKO_AUTH controls auth (see AUTH.md). Auth is ENFORCED by default and covers
# every surface (report intake, the tickets/review API, and the dashboard). The
# ONLY way to turn it off is the explicit local-dev escape hatch below; any other
# value (or unset) means enforced. Uncomment for the keyless single-tenant demo
# (e.g. running the bundled calculator locally):
# PAIKKO_AUTH="disabled"

# PAIKKO_DASHBOARD_PASSWORD is the operator login for the review dashboard
# (/tickets), served over HTTP Basic. The dashboard runs in a browser and can't
# hold a secret key, so the operator logs in with this instead. With auth on and
# this unset, the dashboard fails closed (401). Set a strong random secret.
# PAIKKO_DASHBOARD_PASSWORD="change-me-to-a-long-random-secret"
# PAIKKO_DASHBOARD_USER="admin"   # optional; defaults to "admin"

# PAIKKO_ALLOWED_ORIGINS is the CORS allowlist for cross-origin callers (consumer
# apps that POST reports). Comma-separated list of exact origins. Under enforced
# auth, an UNSET allowlist FAILS CLOSED (same-origin only) - a cross-origin widget
# must have its origin listed here, e.g.:
#   PAIKKO_ALLOWED_ORIGINS="https://app.example.com,https://admin.example.com"
# Only when PAIKKO_AUTH=disabled (dev) is an unset/"*" allowlist permissive
# (reflect any origin), so the calculator on http://localhost:3000 works out of box.
# PAIKKO_ALLOWED_ORIGINS="*"

# PAIKKO_ADMIN_TOKEN enables the project-provisioning endpoint (POST /api/projects,
# which mints a project + its key pair). UNSET = endpoint disabled (404). Set to a
# strong random secret and send it as `Authorization: Bearer <token>` to create
# projects.
# PAIKKO_ADMIN_TOKEN="change-me-to-a-long-random-secret"
