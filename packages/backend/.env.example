# DATABASE_URL is used ONLY by the Prisma CLI for local tooling (migrate diff,
# studio). It is NOT the runtime connection on Cloudflare Workers: there, Prisma
# connects through the D1 binding (`DB`) supplied by @prisma/adapter-d1, not this
# URL. Copy to .env (gitignored) for CLI use.
DATABASE_URL="file:./dev.db"

# PAIKKO_ALLOWED_ORIGINS is the CORS allowlist for cross-origin callers (the
# consumer apps that POST reports + the review UI). Comma-separated list of exact
# origins. UNSET or "*" = permissive: reflect ANY origin (the zero-config dev
# default, so e.g. the calculator on http://localhost:3000 works out of the box).
# Set to an explicit list in production to lock the API down, e.g.:
#   PAIKKO_ALLOWED_ORIGINS="https://app.example.com,https://admin.example.com"
# PAIKKO_ALLOWED_ORIGINS="*"
