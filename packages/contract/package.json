{
  "name": "@paikko/contract",
  "version": "0.1.0",
  "description": "paikko shared wire contract: TS types + zod schemas. Pure, no React, no prisma.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paikko/paikko.git",
    "directory": "packages/contract"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
